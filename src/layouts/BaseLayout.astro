---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../lib/url";
import { Image, getImage } from "astro:assets";
import ogImageSrc from "../assets/images/og-image.jpg";
import gondolaFloat from "../assets/images/logo/gondola-icon.png";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = await getImage({ src: ogImageSrc, width: 1200, height: 630, format: "jpg" });
const ogImageURL = new URL(ogImage.src, Astro.site);

const phone = "+34953505157";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "EventVenue"],
  name: "Salones Venecia",
  image: ogImageURL.toString(),
  url: canonicalURL.toString(),
  telephone: phone,
  address: {
    "@type": "PostalAddress",
    streetAddress: "C. Puerta de Madrid, 7",
    addressLocality: "Andújar",
    addressRegion: "Jaén",
    postalCode: "23740",
    addressCountry: "ES",
  },
  sameAs: ["https://www.instagram.com/salonesvenecia_/"],
};
---

<html lang="es">
  <head>
    <script is:inline>
      // Siempre empezamos en portada al cargar/recargar la página, incluso
      // si la URL trae un ancla (#galeria, #contacto...) de una visita
      // anterior. Los clics normales del menú durante la sesión no se ven
      // afectados: esto solo actúa en la carga inicial.
      if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      const resetScrollToTop = () => window.scrollTo(0, 0);
      resetScrollToTop();
      document.addEventListener("DOMContentLoaded", resetScrollToTop);
      window.addEventListener("load", resetScrollToTop);
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={withBase("favicon.png")} />
    <link rel="apple-touch-icon" href={withBase("apple-touch-icon.png")} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Salones Venecia" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <Image
      src={gondolaFloat}
      alt=""
      width={72}
      height={72}
      id="floating-gondola"
      class="pointer-events-none fixed right-3 top-1/2 z-30 h-9 w-9 object-contain opacity-90 sm:right-6 sm:h-11 sm:w-11"
    />

    <div id="custom-cursor" class="pointer-events-none fixed left-0 top-0 z-[9999] opacity-0">
      <Image src={gondolaFloat} alt="" width={72} height={72} class="custom-cursor-icon h-8 w-8 object-contain" />
    </div>

    <script>
      const revealables = document.querySelectorAll<HTMLElement>("[data-reveal]");
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: "0px 0px -8% 0px" }
      );
      revealables.forEach((el) => observer.observe(el));
    </script>

    <script>
      // Góndola decorativa que "navega" arriba/abajo según el progreso de
      // scroll por toda la página, con un ligero balanceo lateral.
      const boat = document.getElementById("floating-gondola");
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (boat && !reduceMotion) {
        let ticking = false;
        const update = () => {
          const scrollable = document.documentElement.scrollHeight - window.innerHeight;
          const progress = scrollable > 0 ? window.scrollY / scrollable : 0;
          const channel = window.innerHeight * 0.6;
          const travelY = (progress - 0.5) * channel;
          const sway = Math.sin(progress * Math.PI * 10) * 14;
          const tilt = Math.sin(progress * Math.PI * 10) * 8;
          boat.style.transform = `translate(${sway}px, ${travelY}px) rotate(${tilt}deg)`;
          ticking = false;
        };
        update();
        window.addEventListener(
          "scroll",
          () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          },
          { passive: true }
        );
        window.addEventListener("resize", update);
      }
    </script>

    <script>
      // Cursor personalizado (solo en escritorio con ratón/trackpad): una
      // góndola sigue al puntero con un pequeño retraso y gira según la
      // dirección del movimiento, como si estuviera remando.
      const cursor = document.getElementById("custom-cursor");
      const icon = cursor?.querySelector<HTMLElement>(".custom-cursor-icon");
      const isFinePointer = window.matchMedia("(pointer: fine)").matches;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (cursor && isFinePointer && !reduceMotion) {
        document.documentElement.classList.add("custom-cursor-active");

        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        let cursorX = mouseX;
        let cursorY = mouseY;

        window.addEventListener("mousemove", (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          cursor.style.opacity = "1";
        });

        document.addEventListener("mouseleave", () => {
          cursor.style.opacity = "0";
        });

        const render = () => {
          cursorX += (mouseX - cursorX) * 0.18;
          cursorY += (mouseY - cursorY) * 0.18;
          cursor.style.transform = `translate(${cursorX}px, ${cursorY}px)`;

          const dx = mouseX - cursorX;
          const dy = mouseY - cursorY;
          if (icon && (Math.abs(dx) > 1.5 || Math.abs(dy) > 1.5)) {
            const angle = Math.atan2(dy, dx) * (180 / Math.PI);
            icon.style.transform = `translate(-50%, -50%) rotate(${angle + 90}deg)`;
          }

          requestAnimationFrame(render);
        };
        render();
      }
    </script>
  </body>
</html>

<style is:global>
  .js [data-reveal] {
    opacity: 0;
    transform: translateY(1.25rem);
    transition: opacity 0.9s ease, transform 0.9s ease;
  }
  .js [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #floating-gondola {
    will-change: transform;
  }

  #custom-cursor {
    will-change: transform;
  }
  .custom-cursor-icon {
    transition: transform 0.15s ease-out;
    transform: translate(-50%, -50%) rotate(0deg);
    transform-origin: 50% 50%;
  }

  html.custom-cursor-active,
  html.custom-cursor-active * {
    cursor: none !important;
  }
</style>
