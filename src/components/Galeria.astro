---
import { Image, getImage } from "astro:assets";

import boda from "../assets/images/galeria/boda.jpg";
import salon from "../assets/images/instalaciones/salon-banquete.jpg";
import mesaDetalle from "../assets/images/instalaciones/discoteca-ambiente.jpg";
import discoteca from "../assets/images/hero/hero-discoteca.png";
import buffetMarisco from "../assets/images/comida/buffet-marisco.png";
import buffetPostres from "../assets/images/comida/buffet-postres.png";
import chuleton from "../assets/images/comida/chuleton.png";
import cochinillo from "../assets/images/comida/cochinillo.png";
import piernaChoto from "../assets/images/comida/pierna-choto.png";
import carnes from "../assets/images/comida/carnes.png";
import chupitos from "../assets/images/comida/chupitos.png";
import tartas from "../assets/images/comida/tartas-caseras.jpg";

const photos = [
  { src: boda, alt: "Detalle de copa de bienvenida y flores en una boda", tall: true },
  { src: salon, alt: "Salón de banquetes de Salones Venecia", tall: false },
  { src: buffetMarisco, alt: "Buffet de marisco", tall: false },
  { src: cochinillo, alt: "Cochinillo asado", tall: true },
  { src: discoteca, alt: "Ambiente de discoteca en Salones Venecia", tall: false },
  { src: tartas, alt: "Tartas caseras y café", tall: false },
  { src: mesaDetalle, alt: "Detalle de mesa con entrantes", tall: true },
  { src: chuleton, alt: "Chuletón a la brasa", tall: false },
  { src: buffetPostres, alt: "Buffet de postres", tall: false },
  { src: piernaChoto, alt: "Pierna de choto asada", tall: true },
  { src: carnes, alt: "Plato de carnes de Salones Venecia", tall: false },
  { src: chupitos, alt: "Chupitos de licor y bombones", tall: false },
];

const fullSize = await Promise.all(
  photos.map((p) => getImage({ src: p.src, width: 1600, format: "webp", quality: 80 }))
);
---

<section id="galeria" class="bg-brand-950 px-6 py-28 text-beige-50 sm:px-10 lg:py-36">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-2xl" data-reveal>
      <p class="mb-5 text-xs uppercase tracking-[0.4em] text-beige-200/70">Galería</p>
      <h2 class="text-5xl sm:text-6xl">Momentos que hablan por sí solos</h2>
    </div>

    <div id="galeria-grid" class="mt-16 grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4">
      {
        photos.map((photo, i) => (
          <button
            type="button"
            class="lightbox-trigger group relative overflow-hidden rounded-sm"
            data-gallery-card
            data-index={i}
            aria-label={`Ampliar foto: ${photo.alt}`}
          >
            <Image
              src={photo.src}
              alt={photo.alt}
              width={700}
              height={photo.tall ? 875 : 525}
              class={`w-full object-cover transition-transform duration-700 group-hover:scale-105 ${photo.tall ? "aspect-[4/5]" : "aspect-[4/3]"}`}
            />
            <span class="absolute inset-0 bg-brand-950/0 transition-colors duration-300 group-hover:bg-brand-950/10" />
          </button>
        ))
      }
    </div>
  </div>

  <div
    id="lightbox"
    class="fixed inset-0 z-[60] hidden items-center justify-center bg-brand-950/95 p-4 opacity-0 transition-opacity duration-300 sm:p-10"
  >
    <button
      id="lightbox-close"
      type="button"
      aria-label="Cerrar"
      class="absolute right-6 top-6 text-beige-50/80 transition-colors hover:text-beige-50"
    >
      <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M4 4l16 16M20 4L4 20" stroke-linecap="round" />
      </svg>
    </button>
    <button
      id="lightbox-prev"
      type="button"
      aria-label="Foto anterior"
      class="absolute left-3 top-1/2 -translate-y-1/2 text-beige-50/70 transition-colors hover:text-beige-50 sm:left-8"
    >
      <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M15 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <button
      id="lightbox-next"
      type="button"
      aria-label="Foto siguiente"
      class="absolute right-3 top-1/2 -translate-y-1/2 text-beige-50/70 transition-colors hover:text-beige-50 sm:right-8"
    >
      <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <img
      id="lightbox-image"
      src=""
      alt=""
      class="max-h-[85vh] max-w-full rounded-sm object-contain transition-opacity duration-300"
    />
  </div>

  <script is:inline define:vars={{ images: fullSize.map((f, i) => ({ src: f.src, alt: photos[i].alt })) }}>
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-image");
    const triggers = document.querySelectorAll(".lightbox-trigger");
    let currentIndex = 0;

    const show = (index) => {
      currentIndex = (index + images.length) % images.length;
      const item = images[currentIndex];
      lightboxImg.src = item.src;
      lightboxImg.alt = item.alt;
    };

    const open = (index) => {
      show(index);
      lightbox.classList.remove("hidden");
      requestAnimationFrame(() => lightbox.classList.remove("opacity-0"));
      document.body.classList.add("overflow-hidden");
    };

    const close = () => {
      lightbox.classList.add("opacity-0");
      document.body.classList.remove("overflow-hidden");
      setTimeout(() => lightbox.classList.add("hidden"), 300);
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => open(parseInt(trigger.dataset.index, 10)));
    });

    document.getElementById("lightbox-close").addEventListener("click", close);
    document.getElementById("lightbox-prev").addEventListener("click", () => show(currentIndex - 1));
    document.getElementById("lightbox-next").addEventListener("click", () => show(currentIndex + 1));
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener("keydown", (e) => {
      if (lightbox.classList.contains("hidden")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") show(currentIndex - 1);
      if (e.key === "ArrowRight") show(currentIndex + 1);
    });

    let touchStartX = 0;
    let touchStartY = 0;

    lightbox.addEventListener(
      "touchstart",
      (e) => {
        touchStartX = e.changedTouches[0].clientX;
        touchStartY = e.changedTouches[0].clientY;
      },
      { passive: true }
    );

    lightbox.addEventListener(
      "touchend",
      (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) < 50 || Math.abs(dx) < Math.abs(dy)) return;
        if (dx < 0) show(currentIndex + 1);
        else show(currentIndex - 1);
      },
      { passive: true }
    );
  </script>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const cards = gsap.utils.toArray<HTMLElement>("#galeria-grid [data-gallery-card]");

    if (cards.length && !reduceMotion) {
      const groups = [cards.slice(0, 4), cards.slice(4, 8), cards.slice(8, 12)];

      // Si la página carga con la galería ya a la vista (p.ej. recarga con
      // #galeria en la URL), esas fotos no se ocultan: solo animan las que
      // el usuario todavía no ha alcanzado, para evitar el parpadeo de
      // "ocultar y revelar de golpe" al entrar directo por ancla.
      const alreadyInViewThreshold = window.innerHeight * 1.1;
      const notYetReached = cards.filter((card) => card.getBoundingClientRect().top >= alreadyInViewThreshold);

      gsap.set(notYetReached, {
        opacity: 0,
        y: 50,
        z: -220,
        rotateX: () => gsap.utils.random(-14, 14),
        rotateY: () => gsap.utils.random(-14, 14),
        transformPerspective: 1000,
      });

      const animateIn = (targets: HTMLElement[]) => {
        gsap.to(targets, {
          opacity: 1,
          y: 0,
          z: 0,
          rotateX: 0,
          rotateY: 0,
          stagger: 0.08,
          ease: "power2.out",
          duration: 0.9,
          onStart: () => targets.forEach((el) => el.classList.add("is-animating")),
          onComplete: () => targets.forEach((el) => el.classList.remove("is-animating")),
        });
      };

      const mm = gsap.matchMedia();

      mm.add("(min-width: 1024px)", () => {
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: "#galeria-grid",
            start: "top 75%",
            end: "+=90%",
            pin: true,
            scrub: 1,
          },
        });

        groups.forEach((group, i) => {
          tl.to(
            group,
            {
              opacity: 1,
              y: 0,
              z: 0,
              rotateX: 0,
              rotateY: 0,
              stagger: 0.08,
              ease: "power2.out",
              duration: 1,
              onStart: () => group.forEach((el) => el.classList.add("is-animating")),
              onComplete: () => group.forEach((el) => el.classList.remove("is-animating")),
            },
            i * 0.5
          );
        });

        return () => tl.scrollTrigger?.kill();
      });

      mm.add("(max-width: 1023.98px)", () => {
        const triggers = ScrollTrigger.batch(cards, {
          start: "top 88%",
          onEnter: (batch) => animateIn(batch as HTMLElement[]),
          once: true,
        });

        return () => triggers.forEach((t) => t.kill());
      });
    }
  </script>

  <style>
    #galeria-grid [data-gallery-card] {
      backface-visibility: hidden;
    }
    #galeria-grid [data-gallery-card].is-animating {
      will-change: transform, opacity;
    }
  </style>
</section>
