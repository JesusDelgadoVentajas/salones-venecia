---
import { Image } from "astro:assets";
import equipo from "../assets/images/galeria/equipo-direccion.png";

const highlights = [
  {
    title: "Limusina de cortesía",
    text: "Para que los novios lleguen como se merecen.",
  },
  {
    title: "Coche de caballos",
    text: "Una entrada clásica y con encanto, a la andaluza.",
  },
  {
    title: "Taxi inglés de época",
    text: "Un capricho diferente para el gran día.",
  },
  {
    title: "Autobús gratuito",
    text: "Para que los invitados de la comarca no falten a la cita.",
  },
];
---

<section id="historia" class="bg-beige-50 px-6 py-28 sm:px-10 lg:py-36">
  <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-16 lg:grid-cols-2 lg:gap-24">
    <div data-reveal>
      <p class="mb-5 text-xs uppercase tracking-[0.4em] text-chocolate-600">Nuestra historia</p>
      <h2 class="text-5xl text-brand-800 sm:text-6xl">Tradición familiar,<br />de Andújar para Andújar</h2>
      <p class="mt-8 max-w-lg text-lg font-light leading-relaxed text-brand-950/80">
        Somos una empresa familiar con más de 35 años de experiencia en
        hostelería, en pleno corazón de Andújar. Tres décadas escuchando a
        cada familia para que su celebración sea exactamente como la
        imaginaron, con el trato cercano de quien lleva toda la vida en esto.
      </p>
      <p class="mt-5 max-w-lg text-lg font-light leading-relaxed text-brand-950/80">
        Nuestra ubicación céntrica facilita la llegada de todos los
        invitados, y para que el día sea aún más especial, cuidamos también
        los pequeños grandes detalles:
      </p>

      <dl class="mt-10 grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
        {
          highlights.map((item) => (
            <div class="border-t border-chocolate-200/60 pt-4">
              <dt class="font-serif text-xl text-chocolate-700">{item.title}</dt>
              <dd class="mt-1 text-sm font-light text-brand-950/70">{item.text}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="relative" data-reveal>
      <Image
        src={equipo}
        alt="Equipo de dirección de Salones Venecia, Hijos de Juan Delgado"
        width={900}
        height={720}
        class="w-full rounded-sm object-cover shadow-[0_30px_60px_-35px_rgba(3,23,54,0.5)]"
      />
      <p class="mt-4 text-sm font-light italic text-brand-950/60">
        Hijos de Juan Delgado — equipo de dirección de Salones Venecia
      </p>
    </div>
  </div>
</section>
