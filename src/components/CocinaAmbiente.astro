---
import { Image } from "astro:assets";
import BackgroundVideo from "./BackgroundVideo.astro";
import mesaDetalle from "../assets/images/instalaciones/discoteca-ambiente.jpg";
import discotecaPoster from "../assets/images/instalaciones/discoteca-video-poster.jpg";
import chuleton from "../assets/images/comida/chuleton.png";
import tartas from "../assets/images/comida/tartas-caseras.jpg";
---

<section id="cocina" class="bg-brand-950 px-6 py-28 text-beige-50 sm:px-10 lg:py-36">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-2xl" data-reveal>
      <p class="mb-5 text-xs uppercase tracking-[0.4em] text-beige-200/70">Cocina y ambiente</p>
      <h2 class="text-5xl sm:text-6xl">Buena mesa,<br />gran ambiente</h2>
      <p class="mt-8 text-lg font-light leading-relaxed text-beige-100/80">
        Cuidamos cada plato con la misma dedicación de siempre, con
        materia prima de calidad y raciones generosas. Y cuando llega el
        momento del baile, nuestra discoteca y la música en directo ponen
        el broche perfecto a cada celebración.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-6">
      <div class="relative overflow-hidden rounded-sm lg:col-span-5 lg:row-span-2" data-reveal>
        <BackgroundVideo
          mp4="videos/discoteca-ambiente.mp4"
          webm="videos/discoteca-ambiente.webm"
          poster={discotecaPoster}
          alt="Ambiente de discoteca y música en directo en Salones Venecia"
          class="aspect-[3/4] h-full w-full object-cover lg:aspect-auto"
        />
      </div>
      <div class="relative overflow-hidden rounded-sm lg:col-span-7" data-reveal>
        <Image
          src={chuleton}
          alt="Chuletón a la brasa, uno de los platos de Salones Venecia"
          width={700}
          height={430}
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
      <div class="relative overflow-hidden rounded-sm lg:col-span-7" data-reveal>
        <Image
          src={tartas}
          alt="Tartas caseras de repostería propia de Salones Venecia"
          width={700}
          height={430}
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
    </div>

    <div class="mt-16 grid grid-cols-1 items-center gap-10 lg:grid-cols-2" data-reveal>
      <div class="relative overflow-hidden rounded-sm">
        <Image
          src={mesaDetalle}
          alt="Detalle de mesa con entrantes en Salones Venecia"
          width={800}
          height={560}
          class="aspect-[4/3] w-full object-cover"
        />
      </div>
      <p class="text-lg font-light leading-relaxed text-beige-100/80">
        Cada mesa se viste con mimo antes de que lleguen los primeros
        invitados: mantelería cálida, entrantes recién preparados y ese
        detalle artesanal que solo da la experiencia de tres décadas
        sirviendo a las familias de Andújar.
      </p>
    </div>
  </div>
</section>
