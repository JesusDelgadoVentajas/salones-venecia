---
const testimonials = [
  { quote: "[PENDIENTE: testimonio real]", author: "[PENDIENTE: nombre]" },
  { quote: "[PENDIENTE: testimonio real]", author: "[PENDIENTE: nombre]" },
  { quote: "[PENDIENTE: testimonio real]", author: "[PENDIENTE: nombre]" },
];
---

<section id="testimonios" class="bg-beige-50 px-6 py-28 sm:px-10 lg:py-36">
  <div class="mx-auto max-w-5xl text-center">
    <p class="mb-5 text-xs uppercase tracking-[0.4em] text-chocolate-600" data-reveal>
      Testimonios
    </p>
    <h2 class="text-5xl text-brand-800 sm:text-6xl" data-reveal-title><span class="reveal-title-mask">Lo que dicen de nosotros</span></h2>

    <div class="mt-16 grid grid-cols-1 gap-12 sm:grid-cols-3 sm:gap-8">
      {
        testimonials.map((t) => (
          <blockquote class="flex flex-col items-center gap-5" data-reveal>
            <p class="font-serif text-2xl italic leading-snug text-brand-900/50">“{t.quote}”</p>
            <cite class="text-xs uppercase not-italic tracking-widest text-brand-900/40">
              {t.author}
            </cite>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
