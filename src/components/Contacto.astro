---
const address = "C. Puerta de Madrid, 7, 23740 Andújar, Jaén";
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(address)}&output=embed`;
const phoneDisplay = "953 50 51 57";
const phoneHref = "tel:+34953505157";
const instagramHandle = "@salonesvenecia_";
const instagramHref = "https://www.instagram.com/salonesvenecia_/";
---

<section id="contacto" class="bg-beige-100 px-6 py-28 sm:px-10 lg:py-36">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-2xl" data-reveal>
      <p class="mb-5 text-xs uppercase tracking-[0.4em] text-chocolate-600">Contacto</p>
      <h2 class="text-5xl text-brand-800 sm:text-6xl">Hablemos de tu celebración</h2>
      <p class="mt-8 text-lg font-light leading-relaxed text-brand-950/80">
        Llámanos, escríbenos por Instagram o pásate por el salón — estaremos
        encantados de atenderte.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2" data-reveal>
      <a
        href={phoneHref}
        data-copy-phone={phoneDisplay}
        class="group relative flex flex-col justify-between gap-8 rounded-sm border border-brand-800/15 px-8 py-10 transition-colors duration-300 hover:border-brand-800/40"
      >
        <span class="text-xs uppercase tracking-[0.3em] text-chocolate-600">Teléfono</span>
        <span class="font-serif text-4xl text-brand-800 transition-colors group-hover:text-garnet-700 sm:text-5xl">
          {phoneDisplay}
        </span>
        <span
          data-copy-feedback
          class="pointer-events-none absolute right-6 top-6 rounded-full bg-brand-800 px-3 py-1 text-[0.65rem] uppercase tracking-widest text-beige-50 opacity-0 transition-opacity duration-300"
        >
          Copiado
        </span>
      </a>
      <a
        href={instagramHref}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col justify-between gap-8 rounded-sm border border-brand-800/15 px-8 py-10 transition-colors duration-300 hover:border-brand-800/40"
      >
        <span class="text-xs uppercase tracking-[0.3em] text-chocolate-600">Instagram</span>
        <span class="font-serif text-4xl text-brand-800 transition-colors group-hover:text-garnet-700 sm:text-5xl">
          {instagramHandle}
        </span>
      </a>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-8 border-t border-chocolate-300/40 pt-10 sm:grid-cols-2" data-reveal>
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-chocolate-600">Dirección</p>
        <p class="mt-2 font-serif text-2xl text-brand-800">{address}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-chocolate-600">Horario</p>
        <p class="mt-2 font-serif text-2xl text-brand-800">Todos los días, de 7:00 a 23:00</p>
      </div>
    </div>

    <div class="mt-10 overflow-hidden rounded-sm" data-reveal>
      <iframe
        src={mapSrc}
        width="100%"
        height="480"
        style="border:0;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Mapa de Salones Venecia — ${address}`}
      ></iframe>
    </div>
  </div>

  <script>
    const phoneLinks = document.querySelectorAll<HTMLAnchorElement>("[data-copy-phone]");

    phoneLinks.forEach((link) => {
      link.addEventListener("click", () => {
        const value = link.dataset.copyPhone;
        if (!value || !navigator.clipboard) return;
        navigator.clipboard
          .writeText(value)
          .then(() => {
            const feedback = link.querySelector<HTMLElement>("[data-copy-feedback]");
            if (!feedback) return;
            feedback.classList.remove("opacity-0");
            feedback.classList.add("opacity-100");
            setTimeout(() => {
              feedback.classList.remove("opacity-100");
              feedback.classList.add("opacity-0");
            }, 1500);
          })
          .catch(() => {});
      });
    });
  </script>
</section>
