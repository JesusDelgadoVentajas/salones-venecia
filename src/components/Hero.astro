---
import { Image } from "astro:assets";
import limusina from "../assets/images/hero/hero-limusina.png";
---

<section id="inicio" class="relative flex min-h-[100svh] w-full items-end overflow-hidden bg-garnet-950">
  <div data-parallax data-speed="0.15" class="absolute inset-0 -top-16 h-[calc(100%+4rem)]">
    <Image
      src={limusina}
      alt="Limusina de cortesía a la entrada de Salones Venecia, de noche"
      widths={[640, 828, 1200, 1448]}
      sizes="100vw"
      class="h-full w-full scale-105 object-cover object-[30%_50%] sm:object-[38%_50%] lg:object-[50%_42%]"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <div class="absolute inset-0 bg-gradient-to-b from-brand-950/40 via-transparent to-transparent"></div>
  <div class="absolute inset-0 bg-garnet-950/35"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-garnet-950/96 via-garnet-950/80 to-garnet-950/30"></div>

  <canvas id="hero-ripple" class="pointer-events-none absolute inset-0 z-[5] mix-blend-difference"></canvas>

  <div class="relative z-10 w-full px-6 pb-16 sm:px-10 sm:pb-20 lg:pb-24">
    <div class="max-w-2xl" data-reveal>
      <span class="mb-6 inline-block h-px w-10 bg-brand-400"></span>
      <p class="mb-6 text-xs uppercase tracking-[0.4em] text-beige-100/85">
        Andújar &middot; Jaén &middot; desde hace más de 35 años
      </p>
      <h1 class="text-6xl font-bold leading-[1.05] text-beige-50 sm:text-7xl lg:text-[5.5rem]">
        Salones<br />Venecia
      </h1>
      <p class="mt-7 max-w-md text-lg font-light leading-relaxed text-beige-100/90">
        Bodas, comuniones y celebraciones en el corazón de Andújar, donde cada
        detalle se cuida como en familia desde hace más de tres décadas.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-8">
        <a
          href="#contacto"
          class="rounded-full bg-garnet-700 px-8 py-3 text-xs uppercase tracking-widest text-beige-50 transition-colors duration-300 hover:bg-garnet-800"
        >
          Reserva tu fecha
        </a>
        <a
          href="#historia"
          class="group inline-flex items-center gap-2 text-sm text-beige-100/85 transition-colors hover:text-beige-50"
        >
          Nuestra historia
          <span class="h-px w-6 bg-garnet-400 transition-all duration-300 group-hover:w-9"></span>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const layers = document.querySelectorAll<HTMLElement>("[data-parallax]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (layers.length && !reduceMotion) {
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      layers.forEach((layer) => {
        const speed = parseFloat(layer.dataset.speed ?? "0.15");
        layer.style.transform = `translateY(${y * speed}px)`;
      });
      ticking = false;
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
  }
</script>

<script>
  // Ondas de agua al mover el cursor o el dedo sobre el hero, como si se
  // tocara el agua de un canal veneciano.
  const section = document.getElementById("inicio");
  const canvas = document.getElementById("hero-ripple") as HTMLCanvasElement | null;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const ctx = canvas?.getContext("2d");

  if (section && canvas && ctx && !reduceMotion) {
    type Ripple = { x: number; y: number; radius: number; alpha: number };
    let ripples: Ripple[] = [];
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    const resize = () => {
      const rect = section.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = `${rect.width}px`;
      canvas.style.height = `${rect.height}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener("resize", resize);

    const spawnRipple = (x: number, y: number) => {
      ripples.push({ x, y, radius: 0, alpha: 0.45 });
      if (ripples.length > 14) ripples.shift();
    };

    let lastSpawn = 0;
    section.addEventListener(
      "pointermove",
      (e) => {
        const now = performance.now();
        if (now - lastSpawn < 90) return;
        lastSpawn = now;
        const rect = section.getBoundingClientRect();
        spawnRipple(e.clientX - rect.left, e.clientY - rect.top);
      },
      { passive: true }
    );

    section.addEventListener(
      "pointerdown",
      (e) => {
        const rect = section.getBoundingClientRect();
        spawnRipple(e.clientX - rect.left, e.clientY - rect.top);
      },
      { passive: true }
    );

    const render = () => {
      const rect = section.getBoundingClientRect();
      ctx.clearRect(0, 0, rect.width, rect.height);
      ripples.forEach((r) => {
        r.radius += 1.8;
        r.alpha *= 0.955;
      });
      ripples = ripples.filter((r) => r.alpha > 0.02 && r.radius < 90);
      ripples.forEach((r) => {
        ctx.beginPath();
        ctx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(255, 255, 255, ${r.alpha})`;
        ctx.lineWidth = 2;
        ctx.stroke();
      });
      requestAnimationFrame(render);
    };
    render();
  }
</script>
