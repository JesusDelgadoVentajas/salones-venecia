---
import { Image } from "astro:assets";
import copaBienvenida from "../assets/images/galeria/boda.jpg";
import cafeteria from "../assets/images/comida/tartas-caseras.jpg";
import catering from "../assets/images/comida/carnes.png";
import transporte from "../assets/images/hero/hero-limusina.png";

const services = [
  {
    name: "Copa de bienvenida",
    text: "Recibimos a tus invitados con un aperitivo cuidado hasta el último detalle.",
    image: copaBienvenida,
  },
  {
    name: "Cafetería",
    text: "Un espacio de siempre para tomar algo con calma, cualquier día del año.",
    image: cafeteria,
  },
  {
    name: "Catering para eventos",
    text: "Llevamos nuestra cocina fuera de casa para cualquier tipo de celebración.",
    image: catering,
  },
  {
    name: "Transporte de invitados",
    text: "Limusina, coche de caballos, taxi inglés de época y autobús gratuito para la comarca.",
    image: transporte,
  },
];
---

<section id="servicios" class="bg-beige-100 px-6 py-28 sm:px-10 lg:py-36">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-2xl" data-reveal>
      <p class="mb-5 text-xs uppercase tracking-[0.4em] text-chocolate-600">Servicios</p>
      <h2 class="text-5xl font-normal tracking-wide text-garnet-700 sm:text-6xl" data-reveal-title><span class="reveal-title-mask">Todo cuidado, de principio a fin</span></h2>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-x-10 gap-y-16 sm:grid-cols-2">
      {
        services.map((service) => (
          <div class="flex flex-col gap-5" data-reveal>
            <div class="overflow-hidden rounded-sm">
              <Image
                src={service.image}
                alt={service.name}
                width={700}
                height={525}
                class="aspect-[4/3] w-full object-cover"
              />
            </div>
            <div>
              <h3 class="font-serif text-2xl text-brand-800">{service.name}</h3>
              <p class="mt-2 max-w-sm text-sm font-light leading-relaxed text-brand-950/70">
                {service.text}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
