---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import cochinillo from "../assets/images/comida/cochinillo.png";
import buffetMarisco from "../assets/images/comida/buffet-marisco.png";
import buffetPostres from "../assets/images/comida/buffet-postres.png";

interface Category {
  name: string;
  dishes: string | null;
  image: ImageMetadata | null;
  alt?: string;
}

const categories: Category[] = [
  {
    name: "Carnes",
    dishes: "Chuletón, cochinillo asado, pierna de choto…",
    image: cochinillo,
    alt: "Cochinillo asado, plato de carnes de Salones Venecia",
  },
  {
    name: "Mariscos",
    dishes: "Buffet de marisco fresco de temporada",
    image: buffetMarisco,
    alt: "Buffet de marisco de Salones Venecia",
  },
  {
    name: "Postres",
    dishes: "Tartas caseras, buffet de postres, chupitos artesanales",
    image: buffetPostres,
    alt: "Buffet de postres de Salones Venecia",
  },
  {
    name: "Entrantes",
    dishes: null,
    image: null,
  },
  {
    name: "Pescados",
    dishes: null,
    image: null,
  },
];
---

<section id="menu" class="bg-beige-50 px-6 py-28 sm:px-10 lg:py-36">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-2xl" data-reveal>
      <p class="mb-5 text-xs uppercase tracking-[0.4em] text-chocolate-600">Menú</p>
      <h2 class="text-5xl text-brand-800 sm:text-6xl" data-reveal-title><span class="reveal-title-mask">Sabores para cada ocasión</span></h2>
      <p class="mt-8 text-lg font-light leading-relaxed text-brand-950/80">
        Una carta pensada para bodas, comuniones y celebraciones, con
        producto de calidad y raciones pensadas para compartir.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        categories.map((cat) => (
          <div class="group relative overflow-hidden rounded-sm bg-white/40" data-reveal>
            {cat.image ? (
              <Image
                src={cat.image}
                alt={cat.alt ?? cat.name}
                width={700}
                height={520}
                class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            ) : (
              <div class="flex aspect-[4/3] w-full items-center justify-center bg-beige-200/60">
                <span class="font-serif text-lg text-brand-900/35">
                  [PENDIENTE: fotos y platos]
                </span>
              </div>
            )}
            <div class="p-6">
              <h3 class="font-serif text-2xl text-brand-800">{cat.name}</h3>
              <p class="mt-2 text-sm font-light text-brand-950/70">
                {cat.dishes ?? "Próximamente detallaremos esta categoría."}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <div
      class="mt-16 flex flex-col items-start gap-4 border-t border-chocolate-200/60 pt-10 sm:flex-row sm:items-center sm:justify-between"
      data-reveal
    >
      <div>
        <h3 class="font-serif text-2xl text-brand-800">Menús especiales de temporada</h3>
        <p class="mt-2 max-w-md text-sm font-light text-brand-950/70">
          [PENDIENTE: subir PDF con los menús especiales — Navidad, San Valentín, primera comunión…]
        </p>
      </div>
      <span
        class="cursor-not-allowed rounded-full border border-brand-800/30 px-8 py-3 text-xs uppercase tracking-widest text-brand-800/40"
      >
        Descargar PDF
      </span>
    </div>
  </div>
</section>
