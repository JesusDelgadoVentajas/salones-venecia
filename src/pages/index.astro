---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Historia from "../components/Historia.astro";
import CocinaAmbiente from "../components/CocinaAmbiente.astro";
import Menu from "../components/Menu.astro";
import Servicios from "../components/Servicios.astro";
import Galeria from "../components/Galeria.astro";
import Testimonios from "../components/Testimonios.astro";
import EventosVideo from "../components/EventosVideo.astro";
import Contacto from "../components/Contacto.astro";
import SectionDivider from "../components/SectionDivider.astro";
---

<BaseLayout
  title="Salones Venecia | Salón de bodas y eventos en Andújar, Jaén"
  description="Salón de bodas y salón de eventos en Andújar con cafetería propia. Empresa familiar con más de 35 años de experiencia en hostelería. Bodas, comuniones y celebraciones en el corazón de Jaén."
>
  <Hero />
  <SectionDivider from="garnet-950" to="beige-50" height="8rem" />
  <Historia />
  <SectionDivider from="beige-50" to="beige-100" height="3rem" />
  <CocinaAmbiente />
  <SectionDivider from="beige-100" to="beige-50" height="3rem" />
  <Menu />
  <SectionDivider from="beige-50" to="beige-100" height="3rem" />
  <Servicios />
  <SectionDivider from="beige-100" to="brand-950" height="8rem" />
  <Galeria />
  <SectionDivider from="brand-950" to="beige-50" height="8rem" />
  <EventosVideo />
  <Testimonios />
  <SectionDivider from="beige-50" to="beige-100" height="3rem" />
  <Contacto />
  <SectionDivider from="beige-100" to="beige-50" height="3rem" />
</BaseLayout>
